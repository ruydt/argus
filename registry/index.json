        "claudecode",
        "codex"
      ],
      "matcher": "Read|WebFetch|WebSearch|Grep|Bash|Task|mcp__.*",
      "command": "node ~/.argus/hooks/scan-injection.js",
      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "9eb7da1d06cc4409e52fe429fe375802d95de5f2dfa9c4cec852a74f41e330cf",
      "source": "scripts/ruydt/scan-injection.js",
