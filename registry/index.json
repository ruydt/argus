      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "e3e165a836b9797cc4f1367d96753cbd297b9e733635e687bf204d581fa7d06d",
      "source": "scripts/ruydt/scan-injection.js",
