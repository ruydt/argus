    {
      "id": "argus-activate",
      "author": "ruydt",
      "title": "Argus session start",
      "purpose": "Start the Argus server and show a liveness banner at session start.",
      "events": [
        "SessionStart"
      ],
      "agents": [
        "claudecode",
        "codex"
      ],
      "matcher": "",
      "command": "node ~/.argus/hooks/argus-activate.js",
      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "6cf2610cb19352c3ea00ea7ab200aae4a3495cfe1bc51c57e94193bce5a6730a",
      "source": "scripts/ruydt/argus-activate.js",
      "published_at": ""
    },
    {
      "id": "block-dangerous",
      "author": "ruydt",
      "title": "Block dangerous commands",
      "purpose": "Deny dangerous shell commands (rm -rf ~, curl | sh, force-push to main, mkfs) with a reason the agent can act on.",
      "events": [
        "PreToolUse"
      ],
      "agents": [
        "claudecode",
        "codex"
      ],
      "matcher": "Bash",
      "command": "node ~/.argus/hooks/block-dangerous.js",
      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "e1f55d00192e9292bd9bbffbe060b2102b5cf402211be299923382fb8e75b8e6",
      "source": "scripts/ruydt/block-dangerous.js",
      "published_at": ""
    },
    {
