      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "cfe0b095a032a4d221c080e580647f201e112db66329c96b74577846d08aff6e",
      "source": "scripts/ruydt/git-autostage.js",
      "published_at": ""
    },
    {
