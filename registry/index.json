        "claudecode",
        "codex"
      ],
      "matcher": "Read|WebFetch|WebSearch|Grep|Bash|Task|mcp__.*",
      "command": "node ~/.argus/hooks/scan-injection.js",
      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "00123339fd8b694cb73397067527b1da31fe684ebc46e8b84b5cb315f51f2f56",
