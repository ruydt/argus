{
  "schema_version": 1,
  "scripts": [
    {
      "id": "block-dangerous",
      "author": "ruydt",
      "title": "Block dangerous commands",
      "purpose": "Deny dangerous shell commands (rm -rf ~, curl | sh, force-push to main, mkfs) with a reason the agent can act on.",
      "events": [
        "PreToolUse"
      ],
      "agents": [
        "claudecode",
        "codex"
      ],
      "matcher": "Bash",
      "command": "node ~/.argus/hooks/block-dangerous.js",
      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "e1f55d00192e9292bd9bbffbe060b2102b5cf402211be299923382fb8e75b8e6",
      "source": "scripts/ruydt/block-dangerous.js",
      "published_at": ""
    },
    {
      "id": "commit-msg-lint",
      "author": "ruydt",
      "title": "Lint commit messages",
      "purpose": "Block git commits whose message does not follow Conventional Commits (e.g. \"fix(auth): handle expired token\").",
      "events": [
        "PreToolUse"
      ],
      "agents": [
        "claudecode",
        "codex"
      ],
      "matcher": "Bash",
      "command": "node ~/.argus/hooks/commit-msg-lint.js",
      "runtime": "node",
      "os": "linux, macos, windows",
      "tier": "community",
      "sha256": "61aefdacbb3872a6f1ef1316a30a93aa2df39807d5c5df0d1d892b4e18642475",
      "source": "scripts/ruydt/commit-msg-lint.js",
      "published_at": ""
    },
    {
      "id": "cost-warn",
      "author": "ruydt",
      "title": "Cost warning",
      "purpose": "Warn when token usage in the rolling 5h window crosses a threshold. Silent otherwise.",
      "events": [
        "SessionStart"
      ],
      "agents": [
        "claudecode",
        "codex"
      ],
      "matcher": "",
      "command": "node ~/.argus/hooks/cost-warn.js",
      "runtime": "node",
      "os": "linux, macos",
      "tier": "community",
      "sha256": "0bb5c595f3920bb957a606b74d464f0feeda1f3a3b0f7137c5a896db98bd09b7",
      "source": "scripts/ruydt/cost-warn.js",
      "published_at": ""
    },
    {
      "id": "format-lint",
      "author": "ruydt",
      "title": "Format & lint on edit",
      "purpose": "Auto-format the edited file (prettier/ruff/gofmt, single-file) and feed lint errors back so the agent fixes them.",
      "events": [
        "PostToolUse"
      ],
      "agents": [
        "claudecode",
        "codex"
      ],
      "matcher": "Edit|Write|MultiEdit",
      "command": "node ~/.argus/hooks/format-lint.js",
      "runtime": "node",
      "os": "linux, macos",
      "tier": "community",
      "sha256": "3a203d34e2733d921477ecd044f85e285feed4b696ecd7377b29bb9d8d856896",
      "source": "scripts/ruydt/format-lint.js",
      "published_at": ""
    },
    {
      "id": "git-autostage",
      "author": "ruydt",
      "title": "Git autostage",
      "purpose": "Opt-in checkpoint per agent turn: git add -u (tracked files only), optional local commit, never pushes.",
